{
  "name": "dice-travel-agent",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@11.8.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "deploy": "turbo run deploy",
    "typecheck": "turbo run typecheck",
    "typegen": "pnpm --filter @repo/api cf-typegen && pnpm --filter @repo/web cf-typegen",
    "test": "vitest run",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check . && turbo run typecheck && vitest run && turbo run build"
  },
  "author": "yharuto0917",
  "license": "MIT",
  "dependencies": {
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "vitest": "^4.1.9"
  }
}
